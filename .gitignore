# Backend specific data directories (not source code)
backend/ml/models/*  # Only ignore model files, not Python files
backend/caching/data/*  # Only ignore data files, not Python files
backend/analytics/outputs/*  # Only ignore output files, not Python files

# Keep source code files
!backend/ml/*.py
!backend/caching/*.py
!backend/analytics/*.py
!backend/routers/*.py
!backend/src/scripts/*.py
!backend/utils/*.py
!backend/models/*.py
